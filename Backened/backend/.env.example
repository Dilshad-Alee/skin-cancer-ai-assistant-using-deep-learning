# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=Skin Cancer AI
APP_VERSION=1.0.0
DEBUG=false

# ── Model ──────────────────────────────────────────────────────────────────────
# Path inside the container (mapped via Docker volume — do not change)
MODEL_PATH=/app/model/Improved_CNN.keras
IMAGE_SIZE=224
CONFIDENCE_THRESHOLD=0.5

# Name of the last Conv2D layer in your model for GradCAM.
# Leave as "conv2d_last" to auto-detect, or set explicitly, e.g. "block5_conv3"
GRADCAM_LAYER_NAME=conv2d_last

# ── Gemini AI ──────────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated origins, or * for all (development only)
ALLOWED_ORIGINS=["*"]
